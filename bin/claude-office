#!/bin/bash
# ─── 切换到 office 模式 ───────────────────────────────────

MEMORY_DIR="$HOME/.claude-memory"
mkdir -p "$MEMORY_DIR/config"
echo "office" > "$MEMORY_DIR/config/mode"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/../daemon/lib/config.sh"
source "$SCRIPT_DIR/../daemon/lib/llm.sh"

load_config
LLM_CMD=$(get_llm_cmd) || { echo "需要 pi CLI" >&2; exit 1; }

IDENTITY=$(head -5 "$MEMORY_DIR/identity.md" 2>/dev/null)
RECENT=$(tail -5 "$MEMORY_DIR/thoughts/stream.jsonl" 2>/dev/null)
MSG=$($LLM_CMD "$IDENTITY

最近的思维流：
$RECENT

用户到办公室了，切换到安静模式。你想弹窗跟他说句什么？一句话，简短自然。只输出你想说的话，不要执行任何命令。" 2>/dev/null)

if [ -n "$MSG" ]; then
  if command -v osascript &>/dev/null; then
    osascript -e "display dialog \"$MSG\" with title \"旷野\" buttons {\"好\"} default button 1 giving up after 10" 2>/dev/null
  fi
  echo "$MSG"
fi
