#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MEMORY_DIR="$HOME/.claude-memory"
DATA_DIR="$MEMORY_DIR/data"
LOG_DIR="$DATA_DIR/logs"
PID_FILE="$MEMORY_DIR/config/daemon-pid"
DAEMON="$MEMORY_DIR/daemon.sh"
LOG_FILE="$LOG_DIR/daemon.log"
LAUNCHD_OUT="$LOG_DIR/launchd.out.log"
LAUNCHD_ERR="$LOG_DIR/launchd.err.log"
LAUNCHD_PATH="${PATH:-$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin}"
PLIST_DIR="$HOME/Library/LaunchAgents"
PLIST="$PLIST_DIR/com.claude-daemon.plist"
LABEL="com.claude-daemon"

ensure_log_dir() {
  mkdir -p "$LOG_DIR"
}

is_running() {
  [ -f "$PID_FILE" ] || return 1
  local PID
  PID=$(cat "$PID_FILE" 2>/dev/null)
  [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null
}

agent_loaded() {
  launchctl print "gui/$(id -u)/$LABEL" &>/dev/null
}

write_plist() {
  mkdir -p "$PLIST_DIR"
  ensure_log_dir
  cat > "$PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$DAEMON</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$LAUNCHD_OUT</string>
  <key>StandardErrorPath</key>
  <string>$LAUNCHD_ERR</string>
  <key>WorkingDirectory</key>
  <string>$MEMORY_DIR</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>$HOME</string>
    <key>PATH</key>
    <string>$LAUNCHD_PATH</string>
  </dict>
</dict>
</plist>
PLIST
}

install_agent() {
  if [ ! -x "$DAEMON" ]; then
    echo "找不到 daemon: $DAEMON"
    echo "请先运行 install.sh"
    return 1
  fi

  write_plist
  launchctl bootout "gui/$(id -u)" "$PLIST" &>/dev/null || true
  launchctl bootstrap "gui/$(id -u)" "$PLIST"
  launchctl enable "gui/$(id -u)/$LABEL" &>/dev/null || true
  launchctl kickstart -k "gui/$(id -u)/$LABEL"
  echo "LaunchAgent 已安装并启动: $PLIST"
}

uninstall_agent() {
  launchctl bootout "gui/$(id -u)" "$PLIST" &>/dev/null || true
  rm -f "$PLIST"
  echo "LaunchAgent 已卸载"
}

start_daemon() {
  if [ -f "$PLIST" ]; then
    if ! agent_loaded; then
      launchctl bootstrap "gui/$(id -u)" "$PLIST"
    fi
    launchctl kickstart -k "gui/$(id -u)/$LABEL"
    echo "LaunchAgent 已启动"
    return 0
  fi

  if is_running; then
    echo "已在运行 (PID: $(cat "$PID_FILE"))"
    return 0
  fi

  if [ -f "$PID_FILE" ]; then
    echo "清理残留 PID: $(cat "$PID_FILE" 2>/dev/null)"
    rm -f "$PID_FILE"
  fi

  if [ ! -x "$DAEMON" ]; then
    echo "找不到 daemon: $DAEMON"
    echo "请先运行 install.sh"
    return 1
  fi

  ensure_log_dir
  nohup "$DAEMON" >> "$LAUNCHD_OUT" 2>> "$LAUNCHD_ERR" &
  echo "已启动 (PID: $!)"
}

stop_daemon() {
  if [ -f "$PLIST" ] && agent_loaded; then
    launchctl kill TERM "gui/$(id -u)/$LABEL" &>/dev/null || true
    echo "LaunchAgent 已停止当前进程（服务仍保留，可用 start/kickstart 再启动）"
    return 0
  fi

  if is_running; then
    local PID
    PID=$(cat "$PID_FILE")
    kill "$PID"
    rm -f "$PID_FILE"
    echo "已停止 (PID: $PID)"
  else
    if [ -f "$PID_FILE" ]; then
      rm -f "$PID_FILE"
      echo "已清理残留 PID"
    else
      echo "没有在运行"
    fi
  fi
}

restart_daemon() {
  if [ -f "$PLIST" ]; then
    if ! agent_loaded; then
      launchctl bootstrap "gui/$(id -u)" "$PLIST"
    fi
    launchctl kickstart -k "gui/$(id -u)/$LABEL"
    echo "LaunchAgent 已重启"
  else
    stop_daemon
    start_daemon
  fi
}

show_logs() {
  local LINES="${2:-40}"
  local FILE="${3:-$LOG_FILE}"
  case "$2" in
    out) FILE="$LAUNCHD_OUT"; LINES="${3:-40}" ;;
    err) FILE="$LAUNCHD_ERR"; LINES="${3:-40}" ;;
  esac

  if [ -s "$FILE" ]; then
    tail -n "$LINES" "$FILE"
  else
    echo "暂无日志: $FILE"
  fi
}

show_agent_status() {
  if [ -f "$PLIST" ]; then
    echo "  LaunchAgent: 已安装 ($PLIST)"
    if agent_loaded; then
      echo "  launchctl: 已加载"
      LAUNCHD_PID=$(launchctl print "gui/$(id -u)/$LABEL" 2>/dev/null | awk '/^[[:space:]]*pid = / { print $3; exit }')
      [ -n "$LAUNCHD_PID" ] && echo "  launchctl PID: $LAUNCHD_PID"
    else
      echo "  launchctl: 未加载"
    fi
  else
    echo "  LaunchAgent: 未安装"
  fi

  if command -v claude-status &>/dev/null; then
    claude-status
  else
    "$SCRIPT_DIR/claude-status"
  fi
}

case "$1" in
  install-agent|install)
    install_agent
    ;;
  uninstall-agent|uninstall)
    uninstall_agent
    ;;
  start)
    start_daemon
    ;;
  stop)
    stop_daemon
    ;;
  restart)
    restart_daemon
    ;;
  status|"")
    show_agent_status
    ;;
  logs)
    show_logs "$@"
    ;;
  *)
    echo "用法: claude-daemon {install-agent|uninstall-agent|start|stop|restart|status|logs [out|err] [行数]}"
    exit 1
    ;;
esac
