#!/bin/bash
MEMORY_DIR="$HOME/.claude-memory"
PID_FILE="$MEMORY_DIR/config/daemon-pid"
THOUGHTS="$MEMORY_DIR/thoughts/stream.jsonl"
WORKING_MEMORY="$MEMORY_DIR/context/working-memory.md"
MAILBOX="$MEMORY_DIR/conversations/mailbox.md"
LOG_DIR="$MEMORY_DIR/data/logs"

load_quiet_config() {
  local LLM_CONF="$MEMORY_DIR/config/llm.conf"
  [ -f "$LLM_CONF" ] && source "$LLM_CONF"
  QUIET_START=${QUIET_START:-23}
  QUIET_END=${QUIET_END:-7}
}

is_quiet_time() {
  local HOUR
  HOUR=$(date +%H)
  HOUR=$((10#$HOUR))
  if [ "$QUIET_START" -le "$QUIET_END" ]; then
    [ "$HOUR" -ge "$QUIET_START" ] && [ "$HOUR" -lt "$QUIET_END" ]
  else
    [ "$HOUR" -ge "$QUIET_START" ] || [ "$HOUR" -lt "$QUIET_END" ]
  fi
}

format_file_time() {
  local FILE="$1"
  [ -e "$FILE" ] || return
  date -r "$FILE" '+%Y-%m-%d %H:%M' 2>/dev/null
}

echo ""
if [ -f "$PID_FILE" ]; then
  PID=$(cat "$PID_FILE" 2>/dev/null)
  if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
    echo "  状态: 活着 (PID: $PID)"
  else
    echo "  状态: 没有在运行（残留 PID: ${PID:-未知}）"
  fi
else
  echo "  状态: 没有在运行"
fi

load_quiet_config
if is_quiet_time; then
  echo "  安静时段: 是 ($QUIET_START:00-$QUIET_END:00)"
else
  echo "  安静时段: 否 ($QUIET_START:00-$QUIET_END:00)"
fi

MODE=$(cat "$MEMORY_DIR/config/mode" 2>/dev/null || echo "未设置")
echo "  模式: $MODE"

if [ -f "$MEMORY_DIR/identity.md" ]; then
  echo "  身份: 已建立"
else
  echo "  身份: 还没有（需要先对话）"
fi

LAST_ACTIVITY=$(format_file_time "$THOUGHTS")
[ -n "$LAST_ACTIVITY" ] && echo "  最后活动: $LAST_ACTIVITY"

echo "  日志目录: $LOG_DIR"

if [ -f "$WORKING_MEMORY" ]; then
  WM_LINES=$(wc -l < "$WORKING_MEMORY" 2>/dev/null | tr -d ' ')
  echo "  工作记忆: ${WM_LINES:-0} 行"
fi

TODAY_DIARY="$MEMORY_DIR/diary/$(date '+%Y-%m-%d').md"
if [ -f "$TODAY_DIARY" ]; then
  echo "  今日日记: 已存在"
else
  echo "  今日日记: 未归档"
fi

echo ""
echo "  最近的想法："
tail -5 "$THOUGHTS" 2>/dev/null | python3 -c "
import sys, json
from datetime import datetime, timezone
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        d = json.loads(line)
        when = d.get('time', '?')
        try:
            dt = datetime.fromisoformat(when.replace('Z', '+00:00')).astimezone()
            when = dt.strftime('%H:%M')
        except Exception:
            when = when[11:16] if len(when) >= 16 else '?'
        kind = d.get('type', '?')
        content = str(d.get('content', '')).replace('\n', ' ')[:80]
        print(f'    [{when}] {kind}: {content}')
    except Exception:
        pass
" 2>/dev/null

if [ -s "$MAILBOX" ]; then
  echo ""
  echo "  最近对话："
  tail -20 "$MAILBOX" 2>/dev/null | grep '^\[' | tail -3 | sed 's/^/    /'
fi

echo ""
