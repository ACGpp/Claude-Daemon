#!/bin/bash
if command -v claude-daemon &>/dev/null; then
  claude-daemon stop
  exit $?
fi

PID_FILE="$HOME/.claude-memory/config/daemon-pid"

if [ ! -f "$PID_FILE" ]; then
  echo "没有在运行"
  exit 0
fi

PID=$(cat "$PID_FILE" 2>/dev/null)
if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
  kill "$PID"
  echo "已停止 (PID: $PID)"
else
  echo "进程已不存在，已清理残留 PID"
fi

rm -f "$PID_FILE"
